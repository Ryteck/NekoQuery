// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String @id @default(uuid())
  name      String
  email     String @unique
  password  String
  publicKey String @map("public_key")

  participations Participant[]

  @@map("users")
}

model Team {
  id   String @id @default(uuid())
  name String

  slug  String @default("")
  stamp String @default("")

  projects     Project[]
  participants Participant[]

  @@unique([slug, stamp])
  @@map("teams")
}

enum ParticipantLevel {
  ADMIN
  MEMBER

  @@map("participant_level")
}

model Participant {
  userId String @map("user_id")
  user   User   @relation(fields: userId, references: id)

  teamId String @map("team_id")
  team   Team   @relation(fields: teamId, references: id)

  level ParticipantLevel

  nanoIdNonce      String @map("nano_id_nonce")
  nanoIdCiphertext String @map("nano_id_ciphertext")

  @@id([userId, teamId])
  @@map("participants")
}

model Project {
  id   String @id @default(uuid())
  name String

  teamId String @map("team_id")
  team   Team   @relation(fields: teamId, references: id)

  slug  String
  stamp String

  @@unique([slug, stamp])
  @@unique([teamId, slug])
  @@map("projects")
}
